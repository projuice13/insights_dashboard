generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  passwordHash      String
  role              String           @default("team")
  mustChangePass    Boolean          @default(true)
  createdAt         DateTime         @default(now())
  assignments       Assignment[]
  comments          Comment[]
  orders            Order[]
  statusesSet       CustomerStatus[] @relation("StatusSetter")
  statusesApproved  CustomerStatus[] @relation("StatusApprover")
  notifications     Notification[]
}

model CustomerStatus {
  customerId     String    @id
  customerName   String
  status         String    // 'deactivated' | 'dormant' | 'no_response' | 'possible' | 'seasonal' | 'hot'
  approvalStatus String    @default("approved") // 'approved' | 'pending'
  reason         String?
  setById        String
  setAt          DateTime  @default(now())
  approvedById   String?
  approvedAt     DateTime?
  setBy          User      @relation("StatusSetter", fields: [setById], references: [id], onDelete: Cascade)
  approvedBy     User?     @relation("StatusApprover", fields: [approvedById], references: [id])

  @@index([status])
  @@index([approvalStatus])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  type         String   // assignment | deactivation_request | deactivation_approved | deactivation_rejected
  customerId   String
  customerName String
  message      String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model RawOrderRow {
  id               String  @id @default(cuid())
  salesOrderNumber String  @unique
  customerName     String
  postcode         String
  contactName      String
  primaryEmail     String?
  secondaryEmail   String?
  orderValue       Float
  orderDate        String

  @@index([customerName, postcode])
}

model Assignment {
  customerId String   @id
  userId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id           String      @id @default(cuid())
  postcode     String
  address      String
  businessName String
  contactName  String
  phone        String
  openingTimes         String
  deliveryInstructions String  @default("")
  items                OrderItem[]
  placedAt     DateTime    @default(now())
  placedById   String
  placedBy     User        @relation(fields: [placedById], references: [id])
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  product  String
  quantity Int
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([orderId])
}

model Comment {
  id         String   @id @default(cuid())
  customerId String
  userId     String
  text       String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

